# Application
APP_NAME=sahiy-agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false
HOST=0.0.0.0
PORT=8001

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://sahiy:sahiy_test@localhost:5433/sahiy_agent

# Chat LLM: auto | openai | anthropic | rules
# auto = Anthropic → OpenAI → rules (switches on quota/billing/API errors per message)
# anthropic = Claude first, OpenAI fallback if OPENAI_API_KEY is set
# AI_PROVIDER_CHAIN=anthropic,openai  # optional explicit order
AI_PROVIDER=auto
AI_MAX_CONCURRENT=10
AI_TIMEOUT_SECONDS=30

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=
# Ishlaydigan modellar (2026): claude-haiku-4-5-20251001 | claude-sonnet-4-5-20250929
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Embeddings: auto | openai | mock (Claude has no embedding API)
# auto = OpenAI → mock when OpenAI quota is exhausted
EMBEDDING_PROVIDER=auto

# RAG
RAG_SIMILARITY_THRESHOLD=0.85
RAG_TOP_K=3
EMBEDDING_DIMENSION=1536

# Go backend (buyurtma holati)
GO_BACKEND_URL=http://localhost:8080
GO_BACKEND_TIMEOUT_SECONDS=10

# Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_HTTP_TIMEOUT_SECONDS=60
TELEGRAM_SEND_RETRIES=3
