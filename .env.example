# Application
APP_NAME=sahiy-agent
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false
HOST=0.0.0.0
PORT=8001

# Database (matches docker-compose defaults)
DATABASE_URL=postgresql+asyncpg://sahiy:sahiy_test@localhost:5433/sahiy_agent

# Chat LLM: auto | openai | anthropic | rules
# auto = Anthropic → OpenAI → rules (switches on quota/billing/API errors per message)
# anthropic = Claude first, OpenAI fallback if OPENAI_API_KEY is set
# AI_PROVIDER_CHAIN=anthropic,openai  # optional explicit order
AI_PROVIDER=auto
AI_MAX_CONCURRENT=10
AI_TIMEOUT_SECONDS=30

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=
# Ishlaydigan modellar (2026): claude-haiku-4-5-20251001 | claude-sonnet-4-5-20250929
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Embeddings: auto | openai | mock (Claude has no embedding API)
# auto = OpenAI → mock when OpenAI quota is exhausted
EMBEDDING_PROVIDER=auto

# RAG
RAG_SIMILARITY_THRESHOLD=0.85
RAG_TOP_K=7
RAG_MAX_TOKENS=1024
AI_ORDER_MAX_TOKENS=1024
EMBEDDING_DIMENSION=1536

# Go backend (legacy internal proxy; optional if SAHIY_API_* is set)
GO_BACKEND_URL=http://localhost:8080
GO_BACKEND_TIMEOUT_SECONDS=10

# Sahiy API — service_user (login/parol faqat serverda)
SAHIY_API_BASE_URL=https://api.sahiy.uz
SAHIY_API_TIMEOUT_SECONDS=15
SERVICE_USER_PHONE=
SERVICE_USER_PASSWORD=
SERVICE_USER_DEVICE_ID=sahiy-agent
SERVICE_USER_TOKEN_BUFFER_SECONDS=60
SAHIY_DAIGOU_PAGE_SIZE=10
SAHIY_DAIGOU_MAX_PAGES_SEARCH=5
PICKUP_POINTS_CACHE_TTL_SECONDS=3600

# Sahiy admin panel API (SKU + rasm olish uchun)
# Variant A: JWT token to'g'ridan-to'g'ri (panel login → DevTools → Authorization)
SAHIY_ADMIN_ACCESS_TOKEN=
# Variant B: admin_api login (POST /api/admin/v1/token, captcha yo'q)
SAHIY_ADMIN_USERNAME=
SAHIY_ADMIN_PASSWORD=
SAHIY_ADMIN_TOKEN_TTL_SECONDS=3000
SAHIY_ADMIN_CAPTCHA_MAX_ATTEMPTS=5
# Bo'sh qoldiring — ANTHROPIC_MODEL ishlatiladi (masalan claude-haiku-4-5-20251001)
SAHIY_ADMIN_CAPTCHA_MODEL=
# Panel login captcha OCR uchun ANTHROPIC_API_KEY kerak (3-qadam fallback)
SAHIY_SKU_PHOTOS_ENABLED=true

# CNY → UZS (SKU narxlarini so'mda ko'rsatish)
SAHIY_EXCHANGE_API_URL=https://api.abusahiy.uz/api/client/exchange/rates
SAHIY_EXCHANGE_CLIENT_UUID=259bb5ce-16a8-4d4a-81d5-1aaba0ba4a54
SAHIY_EXCHANGE_CACHE_TTL_SECONDS=3600
SAHIY_EXCHANGE_CNY_UZS_FALLBACK=1750

# Telegram (@BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_HTTP_TIMEOUT_SECONDS=60
TELEGRAM_SEND_RETRIES=3
TELEGRAM_TYPING_INTERVAL_SECONDS=4

# Session: auto-close after N hours without messages (0 = disabled)
SESSION_IDLE_HOURS=24

